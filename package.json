{
  "name": "symphony-github-projects",
  "version": "0.1.0",
  "private": true,
  "description": "TypeScript scaffold for Symphony-style orchestrator targeting GitHub Projects",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "symphony-github-projects": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "npm run build && node --test dist/**/*.test.js",
    "start": "node dist/cli.js",
    "dev:dashboard": "npm run build && node dist/cli.js --workflow WORKFLOW.md --dashboard-port 4318"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/node": "^22.19.15",
    "eslint": "^9.22.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1"
  },
  "dependencies": {
    "liquidjs": "^10.24.0",
    "yaml": "^2.8.2"
  }
}
